   "source": [
    "def is_digit(s):\n",
    "    for ch in s:\n",
    "        if ch < '0' or ch > '9' :\n",
    "            return False \n",
    "    return True \n",
    "# s= \"123a45\"\n",
    "s = \"12345\"\n",
    "is_digit(s)"
   ]
