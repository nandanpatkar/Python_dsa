    "s = \"I love python\"\n",
    "\n",
    "\n",
    "\n",
    "a = s.split()\n",
    "b = []\n",
    "for i in range(len(a)-1,-1,-1):\n",
    "    b.append(a[i])\n",
    "\" \".join(b)\n",
    "\n",
    "\n",
    "\n"
