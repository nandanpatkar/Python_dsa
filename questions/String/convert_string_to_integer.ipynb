   ],
   "source": [
    "def stringToInt(s):\n",
    "\n",
    "    num = 0\n",
    "\n",
    "    for ch in s:\n",
    "        digit = ord(ch) - ord('0')\n",
    "        num = num * 10 + digit \n",
    "    return num \n",
    "s = \"507\"\n",
    "stringToInt(s)    "
   ]
