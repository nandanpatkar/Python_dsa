   "source": [
    "def anagram(s1,s2):\n",
    "    if len(s1) != len(s2) :\n",
    "        return False \n",
    "    return sorted(s1) == sorted(s2)\n",
    "s1 = \"listen\"\n",
    "s2 = \"silent\"\n",
    "anagram(s1,s2)"
   ]
