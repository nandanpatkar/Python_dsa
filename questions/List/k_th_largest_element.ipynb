   "source": [
    "import heapq\n",
    "def kth_largest(arr,k):\n",
    "    heap = []\n",
    "\n",
    "    for i in arr:\n",
    "        heapq.heappush(heap,i)\n",
    "        if len(heap) > k:\n",
    "            heapq.heappop(heap)\n",
    "    return heap[0]\n",
    "\n",
    "\n",
    "k = 3 \n",
    "arr = [ 3,2,4,5,7,1]\n",
    "kth_largest(arr,k)"
   ]
